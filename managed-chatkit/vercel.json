{
  "services": {
    "frontend": {
      "root": "managed-chatkit/frontend",
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "root": "managed-chatkit/backend",
      "runtime": "python",
      "entrypoint": "app/main.py",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
